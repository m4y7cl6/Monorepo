{
  "realm": "projecthub",
  "enabled": true,
  "displayName": "ProjectHub Enterprise",
  "accessTokenLifespan": 3600,
  "ssoSessionMaxLifespan": 36000,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "roles": {
    "realm": [
      { "name": "ADMIN", "description": "System Administrator" },
      { "name": "PM", "description": "Project Manager" },
      { "name": "LEADER", "description": "Team Leader" },
      { "name": "DEVELOPER", "description": "Developer" },
      { "name": "TESTER", "description": "QA Tester" },
      { "name": "VIEWER", "description": "Read-only Viewer" }
    ]
  },
  "clients": [
    {
      "clientId": "projecthub-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost/*",
        "http://localhost:4200/*",
        "http://localhost:80/*",
        "http://frontend/*"
      ],
      "webOrigins": [
        "http://localhost",
        "http://localhost:4200",
        "http://localhost:80",
        "http://frontend"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "projecthub-backend",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@projecthub.local",
      "firstName": "System",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "admin123", "temporary": false }],
      "realmRoles": ["ADMIN"]
    },
    {
      "username": "pm.user",
      "email": "pm@projecthub.local",
      "firstName": "Project",
      "lastName": "Manager",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "pm123", "temporary": false }],
      "realmRoles": ["PM"]
    },
    {
      "username": "dev.user",
      "email": "dev@projecthub.local",
      "firstName": "Dev",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "dev123", "temporary": false }],
      "realmRoles": ["DEVELOPER"]
    }
  ],
  "scopeMappings": [],
  "clientScopeMappings": {}
}
